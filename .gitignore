# macOS / editor noise
.DS_Store
._*
.idea/
.vscode/
*.swp
*.swo
*~

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
.coverage.*
htmlcov/

# Virtual environments and local dependency folders
.venv/
venv/
env/
ENV/

# Poetry / packaging build outputs
# Keep poetry.lock tracked for reproducible installs.
dist/
build/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# Local config and secrets
.env
.env.*
!.env.example
*.local

# Logs and runtime output
*.log
logs/

# Experiment/model artifacts that can grow quickly
artifacts/
outputs/
results/
runs/
checkpoints/
*.pickle
*.joblib
*.h5
*.hdf5
*.pt
*.pth
*.onnx

# Temporary files
tmp/
temp/
*.tmp
